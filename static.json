{
  "headers": {
    "/**": {
      "Cache-Control": "no-cache"
    },
    "/index.html": {
      "Cache-Control": "no-store, must-revalidate"
    },
    "/**.css": {
      "Cache-Control": "no-cache"
    },
    "/**.js": {
      "Cache-Control": "no-cache"
    },
    "/**.jpg": {
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/**.png": {
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/**.webp": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  }
}